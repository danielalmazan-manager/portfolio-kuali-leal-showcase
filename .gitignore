# Kuali Leal Technical Showcase - .gitignore

# ─── IMPORTANT: Credentials & Secrets ─────────────────────────────────────────
# NEVER commit sensitive information to Git
.env
.env.local
.env.production
.env.development
*.pem
*.key
*.cert

# Stripe keys (even test keys should not be in git for security best practices)
stripe_secret_*
stripe_webhook_*

# Database credentials
database.json
db_credentials.txt

# SSH keys
id_rsa
id_rsa.pub
*.ppk

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# ─── Next.js Build Output ─────────────────────────────────────────────────────
.next/
out/
build/
dist/

# Next.js cache
.next/cache/

# ─── Prisma ───────────────────────────────────────────────────────────────────
# Generated Prisma Client (auto-generated, should not be committed)
src/generated/
node_modules/.prisma/
node_modules/@prisma/

# Prisma migration lock (if using Prisma Migrate)
# Uncomment if you want to ignore migration lock
# prisma/migrations/**/migration.lock

# ─── TypeScript / JavaScript ──────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
# VSCode
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json

# JetBrains IDEs (WebStorm, IntelliJ IDEA)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# ─── Operating System Files ───────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini

# Linux
*~
.directory
.Trash-*

# ─── Logs & Debugging ─────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# PM2 logs
.pm2/
pm2.log

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# Jest
jest-coverage/

# ─── Temporary Files ──────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ─── Docker ───────────────────────────────────────────────────────────────────
# Ignore actual docker-compose file (use .example as template)
docker-compose.yml
docker-compose.override.yml

# Docker volumes
volumes/

# ─── Backup Files ─────────────────────────────────────────────────────────────
*.bak
*.backup
*.sql.gz
*.dump

# ─── Cloud & Deployment ───────────────────────────────────────────────────────
.vercel
.firebase/
.netlify/

# Terraform
*.tfstate
*.tfstate.backup
.terraform/

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Lock files (keep package-lock.json but ignore others)
# Uncomment the ones you want to ignore
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Sentry
.sentryclirc

# Debug files
debug/
*.debug

# ─── Project Specific ─────────────────────────────────────────────────────────
# Screenshots (if they contain sensitive data)
# Uncomment if needed
# docs/screenshots/*.png
# docs/screenshots/*.jpg

# Actual production config files
ecosystem.config.js
nginx.conf

# ─── What SHOULD be committed ─────────────────────────────────────────────────
# ✅ .env.example (template file)
# ✅ docker-compose.example.yml (template)
# ✅ README.md
# ✅ All markdown documentation
# ✅ Code snippets (sanitized)
# ✅ Prisma schema files
# ✅ package.json
# ✅ tsconfig.json
# ✅ .gitignore (this file)
